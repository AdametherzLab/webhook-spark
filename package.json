    "cli",
    "lcd",
    "oled",
    "iot",
    "ai-agent",
    "dashboard",
    "gauge",
    "arduino",
    "raspberry-pi"
  ],
  "author": "AdametherzLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdametherzLab/webhook-spark.git"
  },
  "homepage": "https://github.com/AdametherzLab/webhook-spark#readme",
  "bugs": {
    "url": "https://github.com/AdametherzLab/webhook-spark/issues"
  },
  "engines": {
    "node": ">=18"
  },
